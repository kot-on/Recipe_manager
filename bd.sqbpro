('Салат Цезарь', 'Салат с курицей, сухариками и соусом.', 5);

INSERT INTO Logs (log_message) VALUES
('добавлен рецепт борщ '),
('Добавлен рецепт Паста карбанара'),
('добавлен рецепт Салат цезарь');
</sql><current_tab id="0"/></tab_sql></sqlb_project>
